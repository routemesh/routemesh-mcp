{
  "name": "@routemesh/mcp",
  "version": "0.1.2",
  "description": "RouteMesh MCP server for cross-chain RPC data and transactions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "verify:live": "tsx scripts/verify-api-server.mts",
    "verify:mcp": "tsx scripts/verify-mcp-tools.mts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "routemesh": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
