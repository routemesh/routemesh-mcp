{
  "mcpServers": {
    "routemesh-local": {
      "command": "node",
      "args": [
        "/ABSOLUTE/PATH/TO/PROJECT/dist/index.js"
      ],
      "env": {
        "ROUTEMESH_API_KEY": "replace-with-your-routemesh-key",
        "ROUTEMESH_MGMT_TOKEN": "replace-with-your-customer-mgmt-token"
      }
    },
    "routemesh": {
      "command": "npx",
      "args": [
        "-y",
        "@routemesh/mcp"
      ],
      "env": {
        "ROUTEMESH_API_KEY": "replace-with-your-routemesh-key",
        "ROUTEMESH_MGMT_TOKEN": "replace-with-your-customer-mgmt-token"
      }
    }
  }
}
