{
  "mcpServers": {
    "routemesh-mcp-local": {
      "command": "node",
      "args": ["/ABSOLUTE/PATH/TO/routemesh-mcp/dist/index.js"],
      "env": {
        "ROUTEMESH_API_KEY": "replace-with-your-routemesh-key"
      }
    },
    "routemesh-mcp-npx": {
      "command": "npx",
      "args": ["-y", "@routemesh/routemesh-mcp"],
      "env": {
        "ROUTEMESH_API_KEY": "replace-with-your-routemesh-key"
      }
    }
  }
}
