ROUTEMESH_API_KEY=replace-with-your-routemesh-key
ROUTEMESH_MGMT_TOKEN=replace-with-your-customer-mgmt-token
ROUTEMESH_API_SERVER_URL=https://api.routeme.sh
ROUTEMESH_BASE_URL=https://lb.routeme.sh
ROUTEMESH_BACKUP_BASE_URL=https://lb2.routeme.sh
ROUTEMESH_TIMEOUT_MS=20000
ROUTEMESH_RETRY_ATTEMPTS=2

# Optional: uncomment to override ROUTEMESH_MGMT_TOKEN for verification scripts
# CUSTOMER_MGMT_TOKEN=replace-with-your-customer-mgmt-token
